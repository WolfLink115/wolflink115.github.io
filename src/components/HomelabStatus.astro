<section class="status">

    <h2>🐺 Wolf's Homelab</h2>

    <p id="summary" class="summary">
        Checking on the floofy server...
    </p>

    <div id="services" class="services"></div>

    <p class="details">
        <a href="https://status.wolflink115.com/status/status">
            View detailed status →
        </a>
    </p>

</section>

<script>
const summary = document.getElementById("summary");
const services = document.getElementById("services");

const ORDER = [
    "Homepage",
    "Immich",
    "Jellyfin",
    "SearXNG",
    "Home Assistant",
    "Portainer",
    "Syncthing",
    "Vaultwarden",
    "Invidious",
];

fetch("/api/homelab")
    .then(r => r.json())
    .then(data => {

        if (data.error) {
            throw new Error(data.message ?? "Offline");
        }

        data.services.sort(
            (a, b) => ORDER.indexOf(a.name) - ORDER.indexOf(b.name)
        );

        summary.textContent =
            `${data.online} / ${data.total} services online`;

        services.innerHTML = "";

        for (const service of data.services) {

            const div = document.createElement("div");
            div.className = "service";

            div.innerHTML = `
                <span>${service.emoji} ${service.name}</span>
                <span class="${service.online ? "online" : "offline"}">
                    ${
                        service.online
                        ? `🟢 ${service.ping} ms`
                        : "🔴 Offline"
                    }
                </span>
            `;

            services.appendChild(div);

        }

    })
    .catch(() => {

        summary.textContent =
            "Couldn't reach the homelab right now.";

    });
</script>

<style>
.status {
    margin: 3rem 0;
    padding: 2rem;
    border-radius: 18px;
    background: #161b22;
    border: 1px solid #30363d;
}

.summary {
    color: #8b949e;
    margin-bottom: 1.5rem;
}

.services {
    display: grid;
    gap: .75rem;
}

.service {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: .85rem 1rem;
    border-radius: 10px;
    background: #0d1117;
}

.online {
    color: #3fb950;
}

.offline {
    color: #f85149;
}

.details {
    margin-top: 1.5rem;
    text-align: center;
}
</style>
