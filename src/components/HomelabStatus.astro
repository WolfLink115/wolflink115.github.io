---
const response = await fetch("/api/homelab");

let data = null;

try {
    data = await response.json();
} catch {
    data = { error: true };
}
---

<section class="status">

<h2>🐺 Wolf's Homelab</h2>

{
data.error ? (

<>
<p>Couldn't reach the homelab right now.</p>

<p class="details">
<a href="https://status.wolflink115.com/status/status">
View detailed status →
</a>
</p>
</>

) : (

<>

<p class="summary">
{data.online} / {data.total} services online
</p>

<div class="services">

{
data.services.map(service => (

<div class="service">

<span>
{service.emoji} {service.name}
</span>

<span class={service.online ? "online" : "offline"}>

{
service.online
? `🟢 ${service.ping} ms`
: "🔴 Offline"
}

</span>

</div>

))
}

</div>

<p class="details">
<a href="https://status.wolflink115.com/status/status">
View detailed status →
</a>
</p>

</>

)

}

</section>

<style>
.status {
    margin: 3rem 0;
    padding: 2rem;
    border-radius: 18px;
    background: #161b22;
    border: 1px solid #30363d;
}

.summary {
    color: #8b949e;
    margin-bottom: 1.5rem;
}

.services {
    display: grid;
    gap: .75rem;
}

.service {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #0d1117;
    padding: .85rem 1rem;
    border-radius: 10px;
}

.online {
    color: #3fb950;
}

.offline {
    color: #f85149;
}

.details {
    margin-top: 1.5rem;
    text-align: center;
}
</style>
